{
    "name": "resumd",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev:web": "npm run dev --workspace=@resumd/web",
        "dev:api": "npm run dev --workspace=@resumd/api",
        "build:web": "npm run build --workspace=@resumd/web",
        "build:api": "npm run build --workspace=@resumd/api",
        "build": "npm run build --workspaces --if-present",
        "format": "prettier --write ."
    }
}
